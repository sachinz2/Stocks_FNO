# =======================================================
# FALCON QUANT PLATFORM — ENVIRONMENT VARIABLES TEMPLATE
# =======================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to git (already in .gitignore)

# ----------------------------
# Application
# ----------------------------
APP_NAME=Falcon Quant Platform
ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ----------------------------
# Database (MySQL)
# ----------------------------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=falcon_db
DB_USER=falcon_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ----------------------------
# Redis
# ----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------
# JWT Authentication
# ----------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING
JWT_EXPIRY_HOURS=24

# ----------------------------
# Zerodha Kite Connect
# ----------------------------
ZERODHA_API_KEY=your_kite_api_key
ZERODHA_API_SECRET=your_kite_api_secret
ZERODHA_USER_ID=your_zerodha_client_id
ZERODHA_PASSWORD=your_zerodha_password
ZERODHA_TOTP_SECRET=your_totp_secret_from_authenticator_app

# ----------------------------
# Telegram Alerts
# ----------------------------
# Create bot: message @BotFather on Telegram -> /newbot
# Get chat_id: send any message to your bot, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ----------------------------
# Trading Configuration
# ----------------------------
# TRADING_MODE: paper (simulated) | live (real money)
# Start with paper. Switch to live only after 45+ days profitable paper trading.
TRADING_MODE=paper
INITIAL_CAPITAL=300000.0
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.05
MAX_EXPOSURE_PCT=0.20

# ----------------------------
# Dashboard
# ----------------------------
DASHBOARD_PASSWORD=choose_a_strong_password
